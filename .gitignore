# ============================================================
# Data — generated by the pipeline, do not commit
# ============================================================
data/
fig/
figures/
*.csv                       # belt-and-braces in case anything escapes data/

# Allow .gitkeep so the data/ folder structure is preserved
!data/.gitkeep
!figures/.gitkeep

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# Editors / OS
# ============================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================
# Secrets — never commit
# ============================================================
.env
*.key
tabpfn_api_key*
